{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"//#check:ci": {
			"cache": false,
			"outputs": []
		},
		"//#check:features": {
			"cache": false,
			"outputs": []
		},
		"build": {
			"outputs": ["dist/**"],
			"dependsOn": ["^build"]
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"lint": {},
		"test": {
			"dependsOn": ["^build", "build"]
		},
		"test:dist": {
			"dependsOn": ["build"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"verify": {
			"dependsOn": ["//#check:ci", "//#check:features", "build", "typecheck", "lint", "test", "test:dist"]
		}
	}
}
