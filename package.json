{
	"name": "cyber-mux-root",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo build",
		"cm": "pnpm run --filter=cyber-mux",
		"check": "biome check --write",
		"check:ci": "biome ci",
		"check:features": "node scripts/check-features.mjs",
		"cs": "changeset",
		"prepare": "node -e \"if(!(process.env.CI||process.env.GITHUB_ACTIONS))require('child_process').execSync('husky',{stdio:'inherit'})\"",
		"release": "changeset publish",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"verify": "turbo verify",
		"version": "changeset version",
		"web": "pnpm run --filter=website"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.29.4",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@cucumber/gherkin": "^41.0.0",
		"@cucumber/messages": "^34.1.0",
		"@repobuddy/biome": "^2.3.1",
		"@types/node": "^24.12.4",
		"husky": "^9.1.7",
		"turbo": "^2.9.14",
		"typescript": "^6.0.0"
	},
	"packageManager": "pnpm@11.0.0",
	"engines": {
		"node": ">=22"
	}
}
